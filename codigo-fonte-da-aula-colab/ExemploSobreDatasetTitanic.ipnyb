00)\n","  model.fit(X_train, y_train)\n","  y_pred = model.predict(X_test)\n","  return y_pred"],"metadata":{"id":"LxTf8u8mx-Br","executionInfo":{"status":"ok","timestamp":1751292441346,"user_tz":180,"elapsed":29,"user":{"displayName":"VICCENZO DE OLIVEIRA NUNES RESENDE","userId":"03358179889791357410"}}},"execution_count":1273,"outputs":[]},{"cell_type":"code","source":["# Função do KNN\n","def knn(X_test, X_train, y_train, y_test,k):\n","  model = KNeighborsClassifier(n_neighbors=k ,metric='euclidean')\n","  model.fit(X_train, y_train)\n","  y_pred = model.predict(X_test)\n","  return y_pred"],"metadata":{"id":"8PKZ1D05yOpQ","executionInfo":{"status":"ok","timestamp":1751292441347,"user_tz":180,"elapsed":27,"user":{"displayName":"VICCENZO DE OLIVEIRA NUNES RESENDE","userId":"03358179889791357410"}}},"execution_count":1274,"outputs":[]},{"cell_type":"code","source":["#Função árvore de decisão\n","def arvore(X_test, X_train, y_test, y_train,k):\n","  model = DecisionTreeClassifier(max_depth=k ,random_state=42)\n","  model.fit(X_train, y_train)\n","  y_pred = model.predict(X_test)\n","  return y_pred"],"metadata":{"id":"akxWzoD6yPJl","executionInfo":{"status":"ok","timestamp":1751292441348,"user_tz":180,"elapsed":25,"user":{"displayName":"VICCENZO DE OLIVEIRA NUNES RESENDE","userId":"03358179889791357410"}}},"execution_count":1275,"outputs":[]},{"cell_type":"code","source":["#Metricas de avaliação de cada modelos\n","#Regressao logistica\n","y_regressao = regressao(X_test, X_train, y_train, y_test)\n","acuraciaRegressao = accuracy_score(y_test, y_regressao)\n","print(f'Acurácia da Regressão Logística:   {acuraciaRegressao}')\n","\n","#KNN\n","y_knn = knn(X_test, X_train, y_train, y_test,20)\n","acuraciaKNN = accuracy_score(y_test, y_knn)\n","print(f'Acurácia do KNN: {acuraciaKNN}')\n","\n","#Arvore de decisão\n","y_arvore = arvore(X_test, X_train, y_test, y_train, 3)\n","acuraciaArvore = accuracy_score(y_test, y_arvore)\n","print(f'Acurácia da Árvore de Decisão: {acu